generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enum ─────────────────────────────────────────────

enum Role {
  OWNER
  MANAGER
  STAFF
}

enum AutoClockOutMode {
  SCHEDULE   // 스케줄 종료 + N분
  MAX_HOURS  // 출근 후 최대 N시간
  MIDNIGHT   // 매일 자정
}

enum InsuranceType {
  NONE         // 미가입
  FOUR_MAJOR   // 4대보험
  THREE_THREE  // 3.3% 원천징수
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ScheduleRequestType {
  CHANGE      // 시간 변경
  CANCEL      // 취소
  SUBSTITUTE  // 대타 요청
}

enum NotificationType {
  ATTENDANCE_REQUEST_APPROVED
  ATTENDANCE_REQUEST_REJECTED
  ATTENDANCE_REQUEST_SUBMITTED
  SCHEDULE_CONFIRMED
  SCHEDULE_REQUEST_APPROVED
  SCHEDULE_REQUEST_REJECTED
  PAYROLL_CONFIRMED
  ANNOUNCEMENT
}

// ─── 사용자 ───────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  phone     String?
  password  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  storeStaffs          StoreStaff[]
  requestedAttendances AttendanceRequest[] @relation("AttendanceRequester")
  reviewedAttendances  AttendanceRequest[] @relation("AttendanceReviewer")
  requestedSchedules   ScheduleRequest[]  @relation("ScheduleRequester")
  reviewedSchedules    ScheduleRequest[]  @relation("ScheduleReviewer")
  notifications        Notification[]
  announcements        Announcement[]

  @@map("users")
}

// ─── 매장 ───────────────────────────────────────────

model Store {
  id             String   @id @default(cuid())
  name           String
  businessOwner  String?
  businessNumber String?
  address        String?
  phone          String?
  mobilePhone    String?
  category       String?
  ownerId        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // 급여일 설정 (1~31)
  payDay Int @default(25)

  // 자동 퇴근 설정
  autoClockOut        Boolean          @default(false)
  autoClockOutMode    AutoClockOutMode @default(MIDNIGHT)
  autoClockOutBuffer  Int              @default(30)   // SCHEDULE 모드: 종료 후 N분
  autoClockOutMaxHours Int             @default(12)   // MAX_HOURS 모드: 최대 N시간

  // 야간 수당 설정 (22:00~06:00)
  nightShiftEnabled    Boolean @default(false)
  nightShiftMultiplier Float   @default(1.5)

  // 초과근무 수당 설정
  overtimeEnabled    Boolean @default(false)
  overtimeMultiplier Float   @default(1.5)

  staffs             StoreStaff[]
  schedules          Schedule[]
  attendances        Attendance[]
  attendanceRequests AttendanceRequest[]
  scheduleRequests   ScheduleRequest[]
  workPreferences    WorkPreference[]
  notifications      Notification[]
  announcements      Announcement[]
  payrolls           Payroll[]

  @@map("stores")
}

// ─── 매장-직원 관계 ────────────────────────────────────

model StoreStaff {
  id         String        @id @default(cuid())
  storeId    String
  userId     String
  role       Role          @default(STAFF)
  hourlyWage Int           @default(10030)
  joinedAt   DateTime      @default(now())
  leftAt     DateTime?

  // 계약·보험
  contractHoursPerMonth Int?          // 월간 계약 근무시간 (시간)
  insuranceType         InsuranceType @default(THREE_THREE)

  // 내부 메모 (오너/매니저만 열람)
  memo String?

  store           Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedules       Schedule[]
  attendances     Attendance[]
  attendanceRequests AttendanceRequest[] @relation("AttendanceStaff")
  scheduleRequests   ScheduleRequest[]  @relation("ScheduleStaff")
  workPreferences WorkPreference[]
  payrolls        Payroll[]

  @@unique([storeId, userId])
  @@map("store_staffs")
}

// ─── 스케줄 ───────────────────────────────────────────

model Schedule {
  id          String   @id @default(cuid())
  storeId     String
  staffId     String   // StoreStaff.id
  startAt     DateTime
  endAt       DateTime
  memo        String?
  isConfirmed Boolean  @default(false)
  isRecurring Boolean  @default(false)
  repeatRule  String?
  createdAt   DateTime @default(now())

  store           Store             @relation(fields: [storeId], references: [id], onDelete: Cascade)
  staff           StoreStaff        @relation(fields: [staffId], references: [id], onDelete: Cascade)
  attendance      Attendance?
  scheduleRequests ScheduleRequest[]

  @@index([storeId, startAt])
  @@map("schedules")
}

// ─── 출퇴근 기록 ──────────────────────────────────────

model Attendance {
  id             String    @id @default(cuid())
  storeId        String
  staffId        String    // StoreStaff.id
  scheduleId     String?   @unique
  clockIn        DateTime
  clockOut       DateTime?
  memo           String?
  isAutoClockOut Boolean   @default(false)
  lat            Float?
  lng            Float?
  createdAt      DateTime  @default(now())

  store             Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  staff             StoreStaff          @relation(fields: [staffId], references: [id], onDelete: Cascade)
  schedule          Schedule?           @relation(fields: [scheduleId], references: [id])
  attendanceRequests AttendanceRequest[]

  @@index([storeId, clockIn])
  @@index([staffId, clockIn])
  @@map("attendances")
}

// ─── 출퇴근 수정 요청 ─────────────────────────────────

model AttendanceRequest {
  id                  String        @id @default(cuid())
  storeId             String
  staffId             String        // StoreStaff.id (대상 알바생)
  requestedById       String        // User.id (요청자 — 알바생 본인 or 오너/매니저)
  attendanceId        String?       // null: 신규 등록, 값: 기존 기록 수정
  requestedClockIn    DateTime
  requestedClockOut   DateTime?
  reason              String
  status              RequestStatus @default(PENDING)
  reviewedById        String?       // User.id
  reviewedAt          DateTime?
  reviewNote          String?
  createdAt           DateTime      @default(now())

  store       Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  staff       StoreStaff  @relation("AttendanceStaff", fields: [staffId], references: [id], onDelete: Cascade)
  requestedBy User        @relation("AttendanceRequester", fields: [requestedById], references: [id])
  attendance  Attendance? @relation(fields: [attendanceId], references: [id])
  reviewedBy  User?       @relation("AttendanceReviewer", fields: [reviewedById], references: [id])

  @@index([storeId, status])
  @@index([staffId])
  @@map("attendance_requests")
}

// ─── 스케줄 변경 요청 ─────────────────────────────────

model ScheduleRequest {
  id                String             @id @default(cuid())
  storeId           String
  staffId           String             // StoreStaff.id
  requestedById     String             // User.id
  scheduleId        String             // 대상 스케줄
  requestType       ScheduleRequestType
  requestedStartAt  DateTime?
  requestedEndAt    DateTime?
  reason            String
  status            RequestStatus      @default(PENDING)
  reviewedById      String?
  reviewedAt        DateTime?
  reviewNote        String?
  createdAt         DateTime           @default(now())

  store       Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  staff       StoreStaff  @relation("ScheduleStaff", fields: [staffId], references: [id], onDelete: Cascade)
  requestedBy User        @relation("ScheduleRequester", fields: [requestedById], references: [id])
  schedule    Schedule    @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  reviewedBy  User?       @relation("ScheduleReviewer", fields: [reviewedById], references: [id])

  @@index([storeId, status])
  @@index([staffId])
  @@map("schedule_requests")
}

// ─── 근무 희망 시간 ───────────────────────────────────

model WorkPreference {
  id          String   @id @default(cuid())
  storeId     String
  staffId     String   // StoreStaff.id
  dayOfWeek   Int      // 0=일, 1=월, ..., 6=토
  startTime   String   // "HH:MM"
  endTime     String   // "HH:MM"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  staff StoreStaff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, dayOfWeek])
  @@index([storeId])
  @@map("work_preferences")
}

// ─── 인앱 알림 ────────────────────────────────────────

model Notification {
  id          String           @id @default(cuid())
  userId      String           // User.id (수신자)
  storeId     String
  type        NotificationType
  title       String
  body        String
  referenceId String?          // 연관 레코드 ID
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

// ─── 공지사항 ─────────────────────────────────────────

model Announcement {
  id        String   @id @default(cuid())
  storeId   String
  authorId  String   // User.id
  title     String
  content   String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store  Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  author User  @relation(fields: [authorId], references: [id])

  @@index([storeId, createdAt])
  @@map("announcements")
}

// ─── 급여 ────────────────────────────────────────────

model Payroll {
  id        String   @id @default(cuid())
  storeId   String
  staffId   String   // StoreStaff.id
  yearMonth String   // "YYYY-MM"

  // 근무 시간 집계 (분 단위)
  totalMinutes    Int @default(0)
  regularMinutes  Int @default(0)  // 정규 근무
  nightMinutes    Int @default(0)  // 야간 근무 (22:00~06:00)
  overtimeMinutes Int @default(0)  // 초과 근무

  // 급여 계산
  basePay          Int @default(0)  // 기본급
  nightAllowance   Int @default(0)  // 야간 수당
  overtimePay      Int @default(0)  // 초과 수당
  weeklyAllowance  Int @default(0)  // 주휴수당
  deduction        Int @default(0)  // 공제액
  netPay           Int @default(0)  // 실지급액

  isConfirmed Boolean  @default(false)
  confirmedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  store Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  staff StoreStaff @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, yearMonth])
  @@index([storeId, yearMonth])
  @@map("payrolls")
}
